# Pulse of London — ingestor secrets.
# Copy this file to `.env` (already gitignored) and fill in REAL values.
# NEVER commit real values, and never paste them into chat.

# TfL Unified API — "Primary access key" from https://api-portal.tfl.gov.uk/
TFL_APP_KEY=your-tfl-primary-access-key

# Cloudflare R2 (S3-compatible). Account ID + an R2 API token (Object Read & Write).
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=pulse-of-london

# Optional overrides (defaults shown):
# SNAPSHOT_KEY=snapshot.json
# TFL_MODES=tube,overground,elizabeth-line,dlr,tram
